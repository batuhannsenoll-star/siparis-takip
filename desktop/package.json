{
  "name": "siparis-takip",
  "version": "1.0.4",
  "description": "Kontraplak Üretim - Sipariş Takip Masaüstü Uygulaması",
  "main": "main.js",
  "author": "Batuhan",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "publish:win": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.4"
  },
  "build": {
    "appId": "com.kontraplak.siparistakip",
    "productName": "Siparis Takip",
    "files": [
      "main.js",
      "index.html"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg"
    },
    "publish": {
      "provider": "github",
      "owner": "batuhannsenoll-star",
      "repo": "siparis-takip",
      "releaseType": "release"
    }
  }
}

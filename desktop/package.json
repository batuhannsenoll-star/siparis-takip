{
  "name": "akis",
  "version": "1.6.0",
  "description": "Anıl Orman Ürünleri - Akış Masaüstü Uygulaması",
  "main": "main.js",
  "author": "Batuhan",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "publish:win": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.4"
  },
  "build": {
    "appId": "com.kontraplak.akis",
    "productName": "Akış",
    "icon": "build/icon.ico",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "config.js",
      "icons/**/*",
      "build/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg"
    },
    "publish": {
      "provider": "github",
      "owner": "batuhannsenoll-star",
      "repo": "akis",
      "releaseType": "release"
    }
  }
}
